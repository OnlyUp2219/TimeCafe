{
  "dashboard": {
    "id": null,
    "title": "TimeCafe Overview",
    "tags": ["timecafe"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Активных визитов",
        "type": "stat",
        "targets": [
          {
            "expr": "timecafe_active_visits_total",
            "legendFormat": "Активные"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Ожидают подтверждения",
        "type": "stat",
        "targets": [
          {
            "expr": "timecafe_visits_pending_total",
            "legendFormat": "Pending"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Выручка (₽)",
        "type": "stat",
        "targets": [
          {
            "expr": "timecafe_revenue_total",
            "legendFormat": "Выручка"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Пользователей",
        "type": "stat",
        "targets": [
          {
            "expr": "timecafe_registered_users_total",
            "legendFormat": "Всего"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "HTTP Request Duration P95",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{service}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
      },
      {
        "id": 6,
        "title": "HTTP Requests per Second",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{service}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
      },
      {
        "id": 7,
        "title": "Визиты за 24ч",
        "type": "graph",
        "targets": [
          {
            "expr": "increase(timecafe_visits_started_total[24h])",
            "legendFormat": "Начато"
          },
          {
            "expr": "increase(timecafe_visits_completed_total[24h])",
            "legendFormat": "Завершено"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12}
      }
    ]
  },
  "overwrite": true
}
