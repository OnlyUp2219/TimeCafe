# TimeCafe Environment Variables Template

ENVIRONMENT=Development

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=Admin123!
AUTH_DB=timecafe_auth
PROFILE_DB=timecafe_profile
VENUE_DB=timecafe_venue
BILLING_DB=timecafe_billing

REDIS_HOST=redis
REDIS_PORT=6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=Admin123!

ELASTICSEARCH_HOSTS=http://elasticsearch:9200
ELASTICSEARCH_NODE_URIS=http://elasticsearch:9200

JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-here
JWT_ISSUER=TimeCafe
JWT_AUDIENCE=TimeCafeAPI
JWT_ACCESS_TOKEN_EXPIRATION=15
JWT_REFRESH_TOKEN_EXPIRATION=7

AUTH_CORS_POLICY=TimeCafe.Auth
USERPROFILE_CORS_POLICY=TimeCafe.UserProfile
VENUE_CORS_POLICY=TimeCafe.Venue
BILLING_CORS_POLICY=TimeCafe.Billing

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
GOOGLE_RECAPTCHA_SECRET=your-recaptcha-secret
CAPTCHA_MOCK_ENABLED=true

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

POSTMARK_SERVER_TOKEN=your-postmark-server-token
POSTMARK_FROM_EMAIL=noreply@timecafe.com
POSTMARK_MESSAGE_STREAM=outbound
FRONTEND_BASE_URL=http://localhost:5173

S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_SERVICE_URL=https://s3.amazonaws.com
S3_BUCKET_NAME=timecafe-profile-photos

SIGHTENGINE_API_USER=your-sightengine-api-user
SIGHTENGINE_API_SECRET=your-sightengine-api-secret
SIGHTENGINE_API_URL=https://api.sightengine.com/1.0/check.json
SIGHTENGINE_MODELS=genai,wad,offensive
PHOTO_MAX_SIZE=5242880

STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_DEFAULT_CURRENCY=usd
STRIPE_DEFAULT_RETURN_URL=http://localhost:5173/payments/return
